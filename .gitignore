# --------------------------------------------------------------------
# Python (Backend & Scripts)
# --------------------------------------------------------------------
# Byte-compiled / Optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments (가상환경 폴더는 절대 커밋하지 않습니다)
venv/
env/
.venv/

# Environment Variables (API Key 등 보안 정보 주의)
.env

# Distribution / Packaging
build/
dist/
*.egg-info/

# Jupyter Notebook
.ipynb_checkpoints/

# Testing
.pytest_cache/
.coverage
debug/
debug.py

# Under construction
js-core/
forge/

# Data: keep the conversion tooling (data/*.py) in VCS so the JS dataset is
# reproducible from a clone, but keep the heavy source/intermediate artifacts out.
data/*.csv
data/*.json
js-data-kr/src/dongnae_cols.json

# Benchmark outputs accumulate per run; the one committed result is kept as
# provenance, future runs are ignored.
benchmark/result/

# --------------------------------------------------------------------
# JavaScript / Web (Frontend)
# --------------------------------------------------------------------
# Dependencies (나중에 npm 등을 쓸 경우를 대비)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs (번들링 결과물 무시, 현재 프로젝트 구조상 src는 커밋해야 함)
# dist/ 

# --------------------------------------------------------------------
# OS & IDE Settings
# --------------------------------------------------------------------
# Mac
.DS_Store

# Windows
Thumbs.db
ehthumbs.db

# VS Code / JetBrains
.vscode/
.idea/

# --------------------------------------------------------------------
# Project Specific (Dongnae Project)
# --------------------------------------------------------------------
